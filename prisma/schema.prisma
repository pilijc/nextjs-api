generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model WatchlistItem {
  id          String   @id @default(cuid())
  viewerId    String
  movieId     Int
  title       String
  posterPath  String?
  releaseDate String?
  voteAverage Float
  createdAt   DateTime @default(now())

  @@unique([viewerId, movieId])
}
